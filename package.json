{
  "name": "phantombot",
  "version": "0.1.0",
  "description": "Personality-first chat agent CLI on Bun. Wraps Claude Code and Pi CLIs with persona, memory, and an OpenClaw persona import path.",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "phantombot": "src/index.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit",
    "build": "mkdir -p dist && bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile dist/phantombot"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "citty": "^0.1.6",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
