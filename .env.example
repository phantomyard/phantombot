# phantombot — example environment file
#
# Copy to .env and fill in. Anything in .env stays out of git (see .gitignore).
# Names are stable for now; treat this file as the authoritative reference.

# === Agent root ===
# Where the agent's persona / memory files live (BOOT.md, MEMORY.md, etc.)
# This is the working directory the harness subprocess will run in.
PHANTOMBOT_AGENT_DIR=./agents/phantom

# === Memory store ===
# SQLite file path. Phantombot creates it on first run if missing.
PHANTOMBOT_MEMORY_DB=./data/memory.sqlite

# === Channels ===

# Telegram bot token. Disable Telegram by leaving this unset.
TELEGRAM_BOT_TOKEN=

# Signal-cli HTTP base URL (the JSON-RPC HTTP wrapper). Disable by leaving unset.
SIGNAL_CLI_URL=
SIGNAL_CLI_NUMBER=

# Google Chat — service account JSON path + workspace project ID.
# Disable by leaving unset.
GOOGLE_CHAT_SERVICE_ACCOUNT=
GOOGLE_CHAT_PROJECT_ID=

# === Harnesses ===
# Each harness is a CLI binary in PATH. Override the binary path here if needed.
# A harness with no override falls back to its default name.
PHANTOMBOT_CLAUDE_BIN=claude
PHANTOMBOT_CODEX_BIN=codex
PHANTOMBOT_GEMINI_BIN=gemini
PHANTOMBOT_PI_BIN=pi

# Comma-separated harness fallback order. First entry = primary.
PHANTOMBOT_HARNESS_CHAIN=claude,codex,gemini,pi

# Per-harness model hints (string passed to each harness's --model flag).
PHANTOMBOT_CLAUDE_MODEL=opus
PHANTOMBOT_CLAUDE_FALLBACK_MODEL=sonnet
PHANTOMBOT_CODEX_MODEL=
PHANTOMBOT_GEMINI_MODEL=
PHANTOMBOT_PI_MODEL=

# Per-turn wall-clock timeout (ms) before phantombot kills the subprocess and
# advances to the next harness in the chain.
PHANTOMBOT_TURN_TIMEOUT_MS=600000

# === Logging ===
PHANTOMBOT_LOG_LEVEL=info
