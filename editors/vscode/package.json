{
  "name": "phantombot-vscode",
  "displayName": "phantombot",
  "description": "Chat with phantombot — your personality-first agent — in VS Code's native Chat panel via an embedded ACP client.",
  "version": "0.4.2",
  "publisher": "phantomyard",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/phantomyard/phantombot.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.124.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "enabledApiProposals": [
    "chatSessionsProvider",
    "chatParticipantPrivate",
    "chatReferenceBinaryData"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:phantombot.chat",
    "onChatSession:phantombot",
    "onCommand:phantombot.openSession"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatSessions": [
      {
        "type": "phantombot",
        "name": "phantombot",
        "displayName": "Phantombot",
        "description": "Your personality-first agent — persona, memory and tools live server-side.",
        "icon": "$(hubot)",
        "canDelegate": true,
        "welcomeTitle": "Phantombot",
        "welcomeMessage": "Chat with phantombot. Persona, memory and tools live server-side, so history and context persist across sessions.",
        "inputPlaceholder": "Message phantombot…",
        "capabilities": {
          "supportsFileAttachments": true,
          "supportsImageAttachments": true
        }
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "phantombot",
        "displayName": "Phantombot"
      }
    ],
    "commands": [
      {
        "command": "phantombot.openSession",
        "title": "Open Phantombot Chat",
        "category": "phantombot",
        "icon": "$(hubot)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "phantombot.openSession"
        }
      ],
      "view/title": [
        {
          "command": "phantombot.openSession",
          "when": "view == workbench.panel.chat.view.copilot",
          "group": "navigation@-1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "phantombot.openSession",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      }
    ],
    "configuration": {
      "title": "phantombot",
      "properties": {
        "phantombot.binaryPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `phantombot` binary. Leave empty to auto-discover via PATH and common install locations."
        },
        "phantombot.persona": {
          "type": "string",
          "default": "",
          "markdownDescription": "Persona to bind the ACP session to (passed as `--persona`). Leave empty to use phantombot's configured default persona."
        },
        "phantombot.openOnStartup": {
          "type": "string",
          "enum": [
            "never",
            "ifPreviouslyOpened",
            "always"
          ],
          "enumDescriptions": [
            "Never auto-open — use the bot button, command palette, or Ctrl+Alt+P / Cmd+Alt+P.",
            "Re-open Phantombot on startup only if it was open when you last closed VS Code (sticky).",
            "Always open Phantombot on startup."
          ],
          "default": "ifPreviouslyOpened",
          "markdownDescription": "Whether to automatically open the Phantombot chat when VS Code starts. Default `ifPreviouslyOpened` makes it _sticky_ — pick Phantombot once and it keeps coming back, leave it closed and it stays out of the way."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "bun run build -- --watch --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./tests"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.104.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
